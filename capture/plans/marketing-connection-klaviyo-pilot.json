    {
      "slug": "builder-providers-klaviyo-connection",
      "targetPath": "/wp-admin/admin.php?page=wpforms-builder&view=providers&form_id=55",
      "keepSidebar": false,
      "keepTopAdminBar": false,
      "waitFor": "#wpforms-panel-providers",
      "steps": [
        { "click": "#wpforms-panel-providers .wpforms-panel-sidebar-section-klaviyo, [data-section=\"klaviyo\"]", "settle": 1000 },
        { "click": "#klaviyo-provider .js-wpforms-builder-provider-connection-add", "settle": 1200 },
        { "eval": "const inp = document.querySelector('.jconfirm input[type=text], .jconfirm input'); if (inp) inp.value = 'Klaviyo Connection';", "settle": 300 },
