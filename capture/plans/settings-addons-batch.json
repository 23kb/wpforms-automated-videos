{
  "_comment": "Builder Settings tab — 6 storage providers (pre+post connection) + 7 form-level addons (panel only). Storage providers use eval-based clicks for resilience and skip the play-around step so the captured connection state is the initial Select Account dropdown only (per the no-premature-cascade rule).",
  "variants": [
    {
      "slug": "builder-settings-dropbox",
      "targetPath": "/wp-admin/admin.php?page=wpforms-builder&view=settings&form_id=55",
      "keepSidebar": false,
      "keepTopAdminBar": false,
      "waitFor": "#wpforms-panel-settings",
      "steps": [
        {
          "click": "#wpforms-panel-settings [data-section=\"dropbox\"]",
          "settle": 1200
        }
      ]
    },
    {
      "slug": "builder-settings-dropbox-connection",
      "targetPath": "/wp-admin/admin.php?page=wpforms-builder&view=settings&form_id=55",
      "keepSidebar": false,
      "keepTopAdminBar": false,
      "waitFor": "#wpforms-panel-settings",
      "steps": [
        {
          "click": "#wpforms-panel-settings [data-section=\"dropbox\"]",
          "settle": 1200
        },
        {
          "eval": "const btn = document.querySelector(\"#dropbox-provider .js-wpforms-builder-provider-connection-add:not(.wpforms-disabled):not(.hidden)\"); if (btn) btn.click(); else console.log(\"dropbox: add-btn disabled\");",
          "settle": 1500
        },
        {
          "eval": "const ok = document.querySelector(\".jconfirm .btn-confirm, .jconfirm .jconfirm-buttons button:not(.btn-default):not(.btn-secondary)\"); if (ok) ok.click();",
          "settle": 2500
        }
      ]
    },
