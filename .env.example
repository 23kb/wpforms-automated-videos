# Local capture credentials for Playwright snapshot capture.
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# WordPress site to capture from (must have WPForms installed).
WP_URL=https://your-wordpress-site.example

# WP admin user with access to WPForms screens.
WP_USER=your-wp-username
WP_PASS=your-wp-password

# WordPress Application Password (Users → Profile → Application Passwords).
# Used by capture/capture.js for authenticated REST calls.
WP_APP_PASS="xxxx xxxx xxxx xxxx xxxx xxxx"
